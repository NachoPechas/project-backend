const userService = require('../services/registrerService');

class UserController {
    async register(req, res) {
        try {
            const { name, email } = req.body;

            if (!name || !email) {
                return res.status(400).json({
                    success: false,
                    message: 'Todos los campos (nombre y correo) son obligatorios.'
                });
            }

            const newUser = await userService.registerStudent({ name, email });

            return res.status(201).json({
                success: true,
                message: 'Estudiante registrado exitosamente.',
                data: {
                    id: newUser.id,
                    name: newUser.name,
                    email: newUser.email,
                    role_id: newUser.role_id,
                    status: newUser.status
                }
            });

        } catch (error) {
            console.error(`[UserController][register] Error: ${error.message}`);
            return res.status(error.status || 500).json({
                success: false,
                message: error.message || 'Error interno en el servidor.'
            });
        }
    }
}

module.exports = new UserController();